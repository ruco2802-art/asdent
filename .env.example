# =========================================================
# SUPABASE
# =========================================================
# Obtener en: https://app.supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<project-id>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>   # SECRETO — nunca al browser

# =========================================================
# ANTHROPIC
# =========================================================
# Obtener en: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# =========================================================
# OPENAI (Whisper — transcripción de audios de WhatsApp)
# =========================================================
# Obtener en: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# =========================================================
# GOOGLE OAUTH (Calendar)
# =========================================================
# Obtener en: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=<client-id>.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
# URI de redirección registrado en Google Cloud Console:
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# =========================================================
# CIFRADO DE TOKENS EN BD (AES-256-GCM)
# =========================================================
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=<32-bytes-en-base64>

# =========================================================
# WHATSAPP WEBHOOK
# =========================================================
# Fallback verify token — usado antes de que haya organizaciones configuradas en BD
# En Meta for Developers, usar este mismo valor como "Verify Token"
WHATSAPP_VERIFY_TOKEN=<token-que-tu-elijas>

# =========================================================
# APP
# =========================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
